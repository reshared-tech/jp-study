    { "id": "tari", "type": "grammar", "jp": "〜たり〜たり", "kana": "", "gloss": "又…又…（列举代表动作；动词た形+り，最后收する）", "example": "お弁当を買ったり、お金を出したりします。", "first_seen": "2026-06-26", "last_seen": "2026-06-30", "exposures": 3, "active_output": 2, "scenes": ["便利店/ATM", "外食自炊"], "connections": ["kanoukei", "de-particle"], "mastery": 3, "due": "2026-07-07", "notes": "N3 9.11。★たり接た形(研究したり/作ったり/買ったり),06-30先误辞書形+たり(研究するたり)纠正后用对。时态只压句尾する。最后收します" },
