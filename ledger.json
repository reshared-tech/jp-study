    { "id": "nitsuite", "type": "grammar", "jp": "〜について", "kana": "", "gloss": "关于…（名词/こと+について，后接言说思考类:話す/考える/書く）", "example": "家を買うことについて、よく考えます。", "first_seen": "2026-06-26", "last_seen": "2026-06-30", "exposures": 2, "active_output": 2, "scenes": ["买房·思考", "双轨复验"], "connections": ["nitotte", "nominalize", "kangaeru"], "mastery": 3, "due": "2026-07-07", "notes": "N3 9.12。について圈话题(后接说/想/写)。★前面动词要用こと打包:買うことについて(不是買うのについて)。与にとって(视角)配对" },
    { "id": "nominalize", "type": "concept", "jp": "名词化 の/こと", "kana": "", "gloss": "把动词变名词的两个工具:の接は/が/だ;こと接について等词组助词;名词本身不用打包", "example": "買うのは難しい / 買うことについて考える", "first_seen": "2026-06-26", "last_seen": "2026-06-30", "exposures": 4, "active_output": 2, "scenes": ["买房分析", "双轨复验"], "connections": ["nitsuite", "nitotte"], "mastery": 3, "due": "2026-07-07", "notes": "★今日3次易错:①の+こと叠用(買うのこと✗)②给名词加の(貯金のは✗,貯金已是名词直接は)③について前用の(買うのについて✗→買うこと)。规律:の后跟光杆は/が;こと后跟词组助词;名词不打包。需继续watch" },
