    { "id": "to-omou", "type": "grammar", "jp": "〜と思う", "kana": "とおもう", "gloss": "我觉得/我认为（と=引号助词，把想法打包交给思う）", "example": "損だと思います。", "first_seen": "2026-06-26", "last_seen": "2026-06-30", "exposures": 2, "active_output": 2, "scenes": ["买房亏不亏", "外食自炊"], "connections": ["son", "tohakagiranai"], "mastery": 3, "active_output_note": "用户最想要的'我觉得'表达。首次纠正后用对'損だと思います'(原误:损だ思うています→漏と+多ています)。钩子=と是思う前的引号；想法直接用思います不加ています", "mastery_was": "教学门槛日:挣扎项满,本项是纠错中自然带出,非主动新增", "notes": "★高频表达观点(★★★★★)。「○○」と思う。注意:と不可省;'觉得'用朴素思います。06-30'自炊のほうが安いと思います'再用对(配のほうが比较)", "due": "2026-07-07" },
